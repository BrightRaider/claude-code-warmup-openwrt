#!/bin/sh
WEBAUTH_FILE=/etc/claudewarmup/webauth
secret=""
[ -s "$WEBAUTH_FILE" ] && secret=$(cat "$WEBAUTH_FILE")

ACTION=""
P_MODE=""
P_HOUR=""
P_MINUTE=""
P_ENABLED=""
P_AUTH=""
P_NEWPW=""

old_ifs=$IFS
IFS='&'
for kv in $QUERY_STRING; do
	qk=${kv%%=*}
	qv=${kv#*=}
	case "$qk" in
		action) ACTION="$qv" ;;
		mode) P_MODE="$qv" ;;
		hour) P_HOUR="$qv" ;;
		minute) P_MINUTE="$qv" ;;
		enabled) P_ENABLED="$qv" ;;
		auth) P_AUTH="$qv" ;;
		newpw) P_NEWPW="$qv" ;;
	esac
done
IFS=$old_ifs

if [ -n "$secret" ] && [ "$P_AUTH" != "$secret" ]; then
	echo "Status: 403 Forbidden"
	echo "Content-Type: application/json"
	echo ""
	echo '{"error":"unauthorized"}'
	exit 0
fi

echo "Content-Type: application/json"
echo ""

status_with_protected() {
	out=$(/usr/bin/claude-warmup.sh status)
	protected=false
	[ -s "$WEBAUTH_FILE" ] && protected=true
	printf '%s,"protected":%s}\n' "${out%\}}" "$protected"
}

case "$ACTION" in
	status)
		status_with_protected
		;;
	set)
		case "$P_MODE" in
			keepwarm|fixed) uci set claudewarmup.settings.mode="$P_MODE" ;;
		esac
		case "$P_HOUR" in
			[0-9]|[0-1][0-9]|2[0-3]) uci set claudewarmup.settings.fixed_hour="$P_HOUR" ;;
		esac
		case "$P_MINUTE" in
			[0-9]|[0-5][0-9]) uci set claudewarmup.settings.fixed_minute="$P_MINUTE" ;;
		esac
		case "$P_ENABLED" in
			0|1) uci set claudewarmup.settings.enabled="$P_ENABLED" ;;
		esac
		uci commit claudewarmup
		/usr/bin/claude-warmup.sh apply
		status_with_protected
		;;
	trigger)
		/usr/bin/claude-warmup.sh fire
		status_with_protected
		;;
	setpw)
		umask 077
		if [ -z "$P_NEWPW" ]; then
			rm -f "$WEBAUTH_FILE"
		else
			printf '%s' "$P_NEWPW" > "$WEBAUTH_FILE"
			chmod 600 "$WEBAUTH_FILE"
		fi
		status_with_protected
		;;
	*)
		echo '{"error":"unknown action"}'
		;;
esac
