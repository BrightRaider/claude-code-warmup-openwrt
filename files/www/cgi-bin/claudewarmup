#!/bin/sh
WEBAUTH_FILE=/etc/claudewarmup/webauth
secret=""
[ -s "$WEBAUTH_FILE" ] && secret=$(cat "$WEBAUTH_FILE")

ACTION=""
P_MODE=""
P_HOUR=""
P_MINUTE=""
P_ENABLED=""
P_AUTH=""
P_NEWPW=""
P_DATE=""
P_LOCALTIME=""

old_ifs=$IFS
IFS='&'
for kv in $QUERY_STRING; do
	qk=${kv%%=*}
	qv=${kv#*=}
	case "$qk" in
		action) ACTION="$qv" ;;
		mode) P_MODE="$qv" ;;
		hour) P_HOUR="$qv" ;;
		minute) P_MINUTE="$qv" ;;
		enabled) P_ENABLED="$qv" ;;
		auth) P_AUTH="$qv" ;;
		newpw) P_NEWPW="$qv" ;;
		date) P_DATE="$qv" ;;
		localtime) P_LOCALTIME="$qv" ;;
	esac
done
IFS=$old_ifs

case "$P_LOCALTIME" in
	[0-9][0-9]:[0-9][0-9]) : ;;
	*) P_LOCALTIME="" ;;
esac

if [ -n "$secret" ] && [ "$P_AUTH" != "$secret" ]; then
	echo "Status: 403 Forbidden"
	echo "Content-Type: application/json"
	echo ""
	echo '{"error":"unauthorized"}'
	exit 0
fi

echo "Content-Type: application/json"
echo ""

status_with_protected() {
	out=$(/usr/bin/claude-warmup.sh status)
	protected=false
	[ -s "$WEBAUTH_FILE" ] && protected=true
	printf '%s,"protected":%s}\n' "${out%\}}" "$protected"
}

case "$ACTION" in
	status)
		status_with_protected
		;;
	set)
		case "$P_MODE" in
			keepwarm|fixed) uci set claudewarmup.settings.mode="$P_MODE" ;;
		esac
		case "$P_HOUR" in
			[0-9]|[0-1][0-9]|2[0-3]) uci set claudewarmup.settings.fixed_hour="$P_HOUR" ;;
		esac
		case "$P_MINUTE" in
			[0-9]|[0-5][0-9]) uci set claudewarmup.settings.fixed_minute="$P_MINUTE" ;;
		esac
		case "$P_ENABLED" in
			0|1) uci set claudewarmup.settings.enabled="$P_ENABLED" ;;
		esac
		uci commit claudewarmup
		/usr/bin/claude-warmup.sh apply "$P_LOCALTIME"
		status_with_protected
		;;
	trigger)
		/usr/bin/claude-warmup.sh fire manual
		status_with_protected
		;;
	log)
		/usr/bin/claude-warmup.sh log
		;;
	setpw)
		umask 077
		if [ -z "$P_NEWPW" ]; then
			rm -f "$WEBAUTH_FILE"
			/usr/bin/claude-warmup.sh logmsg "Password protection removed via web UI"
		else
			printf '%s' "$P_NEWPW" > "$WEBAUTH_FILE"
			chmod 600 "$WEBAUTH_FILE"
			/usr/bin/claude-warmup.sh logmsg "Password protection enabled via web UI"
		fi
		status_with_protected
		;;
	settoken)
		case "$P_DATE" in
			[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9])
				/usr/bin/claude-warmup.sh settoken "$P_DATE"
				;;
		esac
		status_with_protected
		;;
	*)
		echo '{"error":"unknown action"}'
		;;
esac
