config claudewarmup 'settings'
	option enabled '1'
	option mode 'keepwarm'
	option fixed_hour '0'
	option fixed_minute '1'
	option message 'Automated warm-up ping to reset the Claude 5h usage window. Reply with a short acknowledgement.'
	option token_file '/etc/claudewarmup/token'
	option state_file '/etc/claudewarmup/state'
	option log_file '/etc/claudewarmup/warmup.log'
